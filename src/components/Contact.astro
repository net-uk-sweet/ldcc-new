---
import { getEntry } from 'astro:content';
const contact = await getEntry('sections', 'contact');
const { Content } = await contact.render();
const address = contact.data.address;
---

<section id="contact">
  <div class="container">
    <h2>Contact Us</h2>
    <Content />
    {address && (
      <div class="address-block">
        <h3>Find Us</h3>
        <address>
          <span class="address-name">{address.name}</span>
          <span>{address.street}</span>
          <span>{address.postcode}</span>
        </address>
        <div class="map-container">
          <iframe
            src="https://maps.google.com/maps?q=54.0652204,-2.7945434&z=16&output=embed"
            width="100%"
            height="350"
            style="border:0; border-radius:8px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    )}
  </div>
</section>
