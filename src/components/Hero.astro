---
import { getEntry } from 'astro:content';
const hero = await getEntry('sections', 'hero');
const { Content } = await hero.render();
---

<section id="home" class="hero" style={`background-image: url('${import.meta.env.BASE_URL}/images/hero.jpg')`}>
  <div class="hero-overlay">
    <div class="container">
      <Content />
    </div>
  </div>
</section>

<style>
  .hero {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    min-height: 100vh;
    padding: 0;
  }

  .hero-overlay {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero :global(h1),
  .hero :global(p) {
    color: #fff;
  }
</style>
