---
import { getEntry } from 'astro:content';
const volunteers = await getEntry('sections', 'volunteers');
const { Content } = await volunteers.render();
const people = volunteers.data.people ?? [];
---

<section id="volunteers">
  <div class="container">
    <h2>Our Volunteers</h2>
    <Content />
    <div class="card-grid">
      {people.map((person) => (
        <div class="card">
          {person.img ? 
            <img src={`${import.meta.env.BASE_URL}/images/members/${person.img}`} alt={person.name} /> : 
            <img src={`https://ui-avatars.com/api/?name=${encodeURIComponent(person.name)}&size=300&background=1f6f5c&color=fff`} alt={person.name} />} 
          <div class="card-body">
            <h3>{person.name}</h3>
            <p>{person.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
