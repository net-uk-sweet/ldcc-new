---
import { getEntry } from 'astro:content';
const volunteers = await getEntry('sections', 'volunteers');
const { Content } = await volunteers.render();
const people = volunteers.data.people ?? [];
---

<section id="volunteers">
  <div class="container">
    <h2>Our Volunteers</h2>
    <Content />
    <div class="card-grid">
      {people.map((person) => (
        <div class="card">
          <img src={`https://ui-avatars.com/api/?name=${encodeURIComponent(person.name)}&size=300&background=2e6f95&color=fff`} alt={person.name} />
          <div class="card-body">
            <h3>{person.name}</h3>
            <p>{person.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
