---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <div class="nav-container">
        <a href="#home" class="logo"><img src={`${import.meta.env.BASE_URL}/images/logo.jpg`} alt="Lancaster and District Canoe Club logo" /></a>
        <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#places">Places</a></li>
          <li><a href="#volunteers">Volunteers</a></li>
          <li><a href="#courses">Courses</a></li>
          <li><a href="#policies">Policies</a></li>
          <li><a href="#contact">Contact</a></li>
          <li><a href="https://www.facebook.com/groups/759310445829328/" target="_blank" rel="noopener" aria-label="Follow us on Facebook" class="nav-facebook"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a></li>
        </ul>
      </div>
    </nav>
    <script>
      const toggle = document.querySelector('.menu-toggle');
      const nav = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        const open = nav?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
      });
      nav?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).tagName === 'A') {
          nav.classList.remove('open');
          toggle?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} Lancaster and District Canoe Club. All rights reserved.</p>
    </footer>
  </body>
</html>
