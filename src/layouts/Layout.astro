---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <div class="nav-container">
        <a href="#home" class="logo"><img src={`${import.meta.env.BASE_URL}/images/logo.png`} width="100" height="100" alt="Lancaster and District Canoe Club logo" /></a>
        <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#coaches">Coaches</a></li>
          <li><a href="#courses">Courses</a></li>
          <li><a href="#volunteers">Volunteers</a></li>
          <li><a href="#places">Places</a></li>
          <li><a href="#policies">Policies</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </div>
    </nav>
    <script>
      const toggle = document.querySelector('.menu-toggle');
      const nav = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        const open = nav?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
      });
      nav?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).tagName === 'A') {
          nav.classList.remove('open');
          toggle?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} Lancaster and District Canoe Club. All rights reserved.</p>
    </footer>
  </body>
</html>
